# ===== ローカル開発用 (docker-compose.dev.yml) =====
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db
DATABASE_URL=postgresql://user:password@db:5432/db
FRONTEND_ORIGIN=http://localhost:5173

# ===== 共通シークレット =====
GEMINI_API_KEY=

# ===== Vercel 環境変数 (Vercel ダッシュボードで設定) =====
# VITE_API_URL=https://<your-backend-app>.fly.dev

# ===== fly.io シークレット (fly secrets set で設定) =====
# DATABASE_URL は fly postgres attach で自動設定
# fly secrets set GEMINI_API_KEY=<your-key>
# fly secrets set FRONTEND_ORIGIN=https://<your-app>.vercel.app
